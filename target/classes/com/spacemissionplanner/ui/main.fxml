<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.spacemissionplanner.ui.MainController">

    <top>
        <MenuBar>
            <Menu text="File">
                <MenuItem text="New Mission"/>
                <MenuItem text="Open..."/>
                <MenuItem text="Save"/>
                <SeparatorMenuItem/>
                <MenuItem text="Exit"/>
            </Menu>
            <Menu text="Mission">
                <MenuItem text="Add Waypoint" onAction="#onAddWaypoint"/>
                <MenuItem text="Remove Waypoint" onAction="#onRemoveWaypoint"/>
                <SeparatorMenuItem/>
                <MenuItem text="Run Selected" onAction="#onRunMission"/>
                <MenuItem text="Run All Waypoints" onAction="#onRunAllWaypoints"/>
            </Menu>
        </MenuBar>
    </top>

    <center>
        <SplitPane dividerPositions="0.25">
            <!-- Left: Timeline -->
            <VBox spacing="10" style="-fx-padding: 10;">
                <Label text="TIMELINE" style="-fx-font-weight: bold;"/>
                <ListView fx:id="timelineList" prefHeight="400" onMouseClicked="#onWaypointSelected"/>
                <HBox spacing="5">
                    <Button text="+ Add" onAction="#onAddWaypoint"/>
                    <Button text="- Remove" onAction="#onRemoveWaypoint"/>
                </HBox>
                <Button text="Run All Waypoints" onAction="#onRunAllWaypoints"
                        style="-fx-font-weight: bold;"/>
            </VBox>

            <!-- Right: Viewer Tabs -->
            <TabPane fx:id="viewerTabs" tabClosingPolicy="UNAVAILABLE" style="-fx-padding: 0;" minHeight="400">
                <Tab text="3D View">
                    <VBox fx:id="tab3DContent" spacing="5" style="-fx-padding: 5;">
                        <HBox spacing="10">
                            <Button text="Reset View" onAction="#onResetView"/>
                            <Button text="Rotate X+" onAction="#onRotateX"/>
                            <Button text="Rotate X-" onAction="#onRotateXNeg"/>
                            <Button text="Rotate Y+" onAction="#onRotateY"/>
                            <Button text="Rotate Y-" onAction="#onRotateYNeg"/>
                        </HBox>
                        <HBox spacing="10">
                            <Label text="Camera Target:"/>
                            <Button text="Earth" onAction="#onTargetEarth"/>
                            <Button text="Spacecraft" onAction="#onTargetSpacecraft"/>
                        </HBox>
                    </VBox>
                </Tab>
                <Tab text="2D View">
                    <VBox fx:id="tab2DContent" spacing="5" style="-fx-padding: 5;"/>
                </Tab>
            </TabPane>
        </SplitPane>
    </center>

    <bottom>
        <VBox spacing="5" style="-fx-padding: 10; -fx-background-color: #f0f0f0;">
            <Label text="ORBIT INPUT (Selected Waypoint)" style="-fx-font-weight: bold;"/>
            <GridPane hgap="10" vgap="5">
                <Label text="a (km):" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="tfSemiMajorAxis" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="80"/>

                <Label text="e:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <TextField fx:id="tfEccentricity" GridPane.columnIndex="3" GridPane.rowIndex="0" prefWidth="60"/>

                <Label text="i (°):" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                <TextField fx:id="tfInclination" GridPane.columnIndex="5" GridPane.rowIndex="0" prefWidth="60"/>

                <Label text="Ω (°):" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="tfRaan" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="80"/>

                <Label text="ω (°):" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                <TextField fx:id="tfArgPeriapsis" GridPane.columnIndex="3" GridPane.rowIndex="1" prefWidth="60"/>

                <Label text="ν (°):" GridPane.columnIndex="4" GridPane.rowIndex="1"/>
                <TextField fx:id="tfTrueAnomaly" GridPane.columnIndex="5" GridPane.rowIndex="1" prefWidth="60"/>
            </GridPane>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Run Mission" onAction="#onRunMission"
                        style="-fx-font-size: 14px; -fx-padding: 8 20;"/>
                <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: #333;"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>