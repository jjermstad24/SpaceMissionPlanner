<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.spacemissionplanner.ui.MainController">

    <top>
        <VBox>
            <MenuBar>
                <Menu text="File">
                    <MenuItem text="New Mission"/>
                    <MenuItem text="Open..."/>
                    <MenuItem text="Save"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Exit"/>
                </Menu>
                <Menu text="Mission">
                    <MenuItem text="Add Waypoint" onAction="#onAddWaypoint"/>
                    <MenuItem text="Add Maneuver" onAction="#onAddManeuver"/>
                    <MenuItem text="Add Coast" onAction="#onAddCoast"/>
                    <MenuItem text="Remove" onAction="#onRemoveWaypoint"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Run Selected" onAction="#onRunMission"/>
                    <MenuItem text="Run All" onAction="#onRunAllWaypoints"/>
                </Menu>
            </MenuBar>
            <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 5 10; -fx-background-color: #e0e0e0;">
                <Label text="Camera:"/>
                <ComboBox fx:id="cbCameraTarget" prefWidth="120"/>
                <Label text="Epoch:"/>
                <ComboBox fx:id="cbEpochFormat" prefWidth="100"/>
                <TextField fx:id="tfEpochValue" prefWidth="220" promptText="2024-01-15T12:00:00"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.25">
            <!-- Left: Timeline -->
            <VBox spacing="10" style="-fx-padding: 10;">
                <Label text="TIMELINE" style="-fx-font-weight: bold;"/>
                <ListView fx:id="timelineList" prefHeight="400"/>
                <HBox spacing="5">
                    <MenuButton text="+ Add" style="-fx-font-weight: bold;">
                        <items>
                            <MenuItem text="Waypoint" onAction="#onAddWaypoint"/>
                            <MenuItem text="Maneuver" onAction="#onAddManeuver"/>
                            <MenuItem text="Coast" onAction="#onAddCoast"/>
                        </items>
                    </MenuButton>
                    <Button text="- Remove" onAction="#onRemoveWaypoint"/>
                </HBox>
                <Button text="Run All Events" onAction="#onRunAllWaypoints"
                        style="-fx-font-weight: bold;"/>
            </VBox>

            <!-- Right: Viewer Tabs -->
            <TabPane fx:id="viewerTabs" tabClosingPolicy="UNAVAILABLE" style="-fx-padding: 0;" minHeight="400">
                <Tab text="3D View">
                    <VBox fx:id="tab3DContent" spacing="5" style="-fx-padding: 5;"/>
                </Tab>
                <Tab text="2D View">
                    <VBox fx:id="tab2DContent" spacing="5" style="-fx-padding: 5;"/>
                </Tab>
                <Tab text="Bodies">
                    <VBox fx:id="tabBodiesContent" spacing="5" style="-fx-padding: 10;"/>
                </Tab>
            </TabPane>
        </SplitPane>
    </center>

    <bottom>
        <VBox spacing="5" style="-fx-padding: 10; -fx-background-color: #f0f0f0;">
            <Label fx:id="inputPanelTitle" text="ORBIT INPUT" style="-fx-font-weight: bold;"/>

            <VBox fx:id="orbitInputPanel" managed="true" spacing="5">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Frame:"/>
                    <ComboBox fx:id="cbWaypointFrame" prefWidth="180"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Body:"/>
                    <ComboBox fx:id="cbWaypointBody" prefWidth="120"/>
                </HBox>
                <GridPane hgap="10" vgap="5">
                    <Label fx:id="lblOrbit1" text="a (km):" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfOrbit1" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="80"/>

                    <Label fx:id="lblOrbit2" text="e:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfOrbit2" GridPane.columnIndex="3" GridPane.rowIndex="0" prefWidth="60"/>

                    <Label fx:id="lblOrbit3" text="i (°):" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfOrbit3" GridPane.columnIndex="5" GridPane.rowIndex="0" prefWidth="60"/>

                    <Label fx:id="lblOrbit4" text="Ω (°):" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="tfOrbit4" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="80"/>

                    <Label fx:id="lblOrbit5" text="ω (°):" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                    <TextField fx:id="tfOrbit5" GridPane.columnIndex="3" GridPane.rowIndex="1" prefWidth="60"/>

                    <Label fx:id="lblOrbit6" text="ν (°):" GridPane.columnIndex="4" GridPane.rowIndex="1"/>
                    <TextField fx:id="tfOrbit6" GridPane.columnIndex="5" GridPane.rowIndex="1" prefWidth="60"/>
                </GridPane>
            </VBox>

            <VBox fx:id="maneuverInputPanel" managed="true" visible="false" spacing="5">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Frame:"/>
                    <ComboBox fx:id="cbManeuverFrame" prefWidth="160"/>
                </HBox>
                <GridPane hgap="10" vgap="5">
                    <Label fx:id="lblDvx" text="dVx (m/s):" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfDvx" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="80"/>

                    <Label fx:id="lblDvy" text="dVy (m/s):" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfDvy" GridPane.columnIndex="3" GridPane.rowIndex="0" prefWidth="80"/>

                    <Label fx:id="lblDvz" text="dVz (m/s):" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfDvz" GridPane.columnIndex="5" GridPane.rowIndex="0" prefWidth="80"/>
                </GridPane>
            </VBox>

            <VBox fx:id="coastInputPanel" managed="true" visible="false">
                <GridPane hgap="10" vgap="5">
                    <Label text="Duration (s):" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfCoastDuration" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="100"/>
                    <Label text="Step Size (s):" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfCoastStepSize" GridPane.columnIndex="3" GridPane.rowIndex="0" prefWidth="60" text="60"/>
                </GridPane>
            </VBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Color:"/>
                <ColorPicker fx:id="eventColorPicker"/>
                <Button text="Run Mission" onAction="#onRunMission"
                        style="-fx-font-size: 14px; -fx-padding: 8 20;"/>
                <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: #333;"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>